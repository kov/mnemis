{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mnemis",
  "version": "0.1.0",
  "identifier": "eti.noronha.mnemis",
  "build": {
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mnemis",
        "width": 1100,
        "height": 750,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
